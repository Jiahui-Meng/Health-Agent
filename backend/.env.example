HEALTH_AGENT_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/health_agent
# Default provider: Codex CLI login (OpenAI account)
HEALTH_AGENT_PROVIDER_MODE=codex_cli
HEALTH_AGENT_CODEX_CLI_BIN=codex
HEALTH_AGENT_MCP_MODE=stdio
HEALTH_AGENT_MODEL_BASE_URL=https://api.openai.com/v1
HEALTH_AGENT_MODEL_API_KEY=
HEALTH_AGENT_MODEL_NAME=gpt-5.4
HEALTH_AGENT_MODEL_TIMEOUT_SECONDS=45
HEALTH_AGENT_PROMPTS_DIR=prompts
HEALTH_AGENT_PROMPT_LOCALE_FALLBACK=en
HEALTH_AGENT_CONTEXT_TURN_LIMIT=6
HEALTH_AGENT_MAX_CONTEXT_CHARS=5000
